# ============================================

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# --- Supabase ---
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=salon-media

# --- JWT ---
# In production, set this to a strong secret. If unset, the app will:
# 1. Check for jwt_secret.txt file
# 2. Generate an ephemeral random secret (single-instance only)
JWT_SECRET_KEY=

# --- Server ---
BACKEND_PORT=8080
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080

# --- External Integrations (Optional) ---
# Naver Booking API
NAVER_BOOKING_API_KEY=
NAVER_BOOKING_API_SECRET=

# SMS/Notification Provider
SMS_API_KEY=
SMS_SENDER_NUMBER=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@salon-core.app

# --- Rate Limiting ---
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20
